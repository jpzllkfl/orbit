{
  "name": "orbit-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k \"npm run server:watch\" \"npm run dev\"",
    "server": "node server/index.js",
    "server:watch": "node --watch server/index.js",
    "build": "cross-env VITE_PLEX_PROXY=1 tsc -b && cross-env VITE_PLEX_PROXY=1 vite build",
    "build:docker": "cross-env VITE_PLEX_PROXY=1 npm run build",
    "start": "node server/index.js",
    "desktop": "npm run build && electron .",
    "desktop:dev": "npm run build && cross-env ORBIT_ELECTRON_DEBUG=1 DEBUG_PLEX=1 electron .",
    "predist:win": "node scripts/prebuild-installer.mjs",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:win:portable": "npm run build && electron-builder --win portable",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "express": "^4.21.2",
    "hls.js": "^1.6.16",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "build": {
    "appId": "com.broken-eye.orbit",
    "productName": "Orbit",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "Orbit-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Orbit"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
